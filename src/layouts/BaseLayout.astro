---
import { createHash } from 'node:crypto';
import siteConfig from '../site.config';
import '../styles/global.scss';

export interface ArticleMeta {
  publishedTime: Date;
  modifiedTime?: Date;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description?: string;
  socialImage?: string;
  /** Present on post pages — toggles og:type=article and emits article:* meta. */
  article?: ArticleMeta;
  /** schema.org JSON-LD payload — emitted as <script type="application/ld+json">. */
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = siteConfig.subtitle,
  socialImage,
  article,
  structuredData,
} = Astro.props;
const { author, url } = siteConfig;
const metaImage = socialImage ?? author.photo;
const metaImageUrl = new URL(metaImage, url).toString();
const canonicalUrl = new URL(Astro.url.pathname, url).toString();
// Large card when there's a real social image; small card otherwise.
const twitterCard = socialImage ? 'summary_large_image' : 'summary';
const ogType = article ? 'article' : 'website';

// Inline script bodies — fixed across all pages. Defined as constants so the
// CSP sha256 hash matches the exact bytes the browser parses.
const antiFlashScript = `(()=>{try{const t=localStorage.getItem('theme');if(t==='light'||t==='dark')document.documentElement.dataset.theme=t;}catch{}})();`;
const speculationRules = JSON.stringify({
  prerender: [
    {
      where: { and: [{ href_matches: '/*' }, { not: { href_matches: '/rss.xml' } }] },
      eagerness: 'moderate',
    },
  ],
});
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : null;

const sha256 = (body: string): string =>
  `'sha256-${createHash('sha256').update(body, 'utf8').digest('base64')}'`;

const scriptSources = ["'self'", sha256(antiFlashScript), sha256(speculationRules)];
if (structuredDataJson) scriptSources.push(sha256(structuredDataJson));

// Scoped <style> blocks Astro emits are inlined → style-src still needs 'unsafe-inline'.
// We do NOT need 'unsafe-inline' on script-src now that every inline script is hashed.
const csp = [
  "default-src 'self'",
  "img-src 'self' https: data:",
  `script-src ${scriptSources.join(' ')}`,
  "style-src 'self' 'unsafe-inline'",
  "connect-src 'self' https://public.api.bsky.app",
  "font-src 'self'",
  "base-uri 'self'",
  "form-action 'none'",
  "object-src 'none'",
].join('; ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    {/* Anti-flash: apply stored theme before first paint. Sync with ThemeToggle.astro. */}
    <script is:inline set:html={antiFlashScript} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" sizes="32x32" href="/favicon-32x32.png" type="image/png" />
    <link rel="icon" sizes="16x16" href="/favicon-16x16.png" type="image/png" />
    <link rel="mask-icon" color="#5bbad5" href="/safari-pinned-tab.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    {/* Browser chrome color — dark variant matches --color-white in dark mode (_tokens.scss). */}
    <meta name="theme-color" content="#F7A046" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f1115" media="(prefers-color-scheme: dark)" />
    <script type="speculationrules" is:inline set:html={speculationRules} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={metaImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime.toISOString()} />
        {article.modifiedTime && (
          <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />
        )}
        <meta property="article:author" content={author.name} />
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImageUrl} />
    {structuredDataJson && (
      <script type="application/ld+json" is:inline set:html={structuredDataJson} />
    )}
    <slot name="head" />
  </head>
  <script>
    // Wire up code-block copy buttons (injected by the rehypeCodeCopy plugin).
    const initCodeCopy = () => {
      document.querySelectorAll<HTMLButtonElement>('[data-code-copy]').forEach((btn) => {
        if (btn.dataset.codeCopyBound) return;
        btn.dataset.codeCopyBound = 'true';
        btn.addEventListener('click', async () => {
          const pre = btn.nextElementSibling;
          const code = pre?.querySelector('code')?.textContent ?? pre?.textContent ?? '';
          try {
            await navigator.clipboard.writeText(code);
            const original = btn.textContent;
            btn.textContent = 'Copied!';
            btn.dataset.copied = 'true';
            setTimeout(() => {
              btn.textContent = original;
              delete btn.dataset.copied;
            }, 1500);
          } catch (err) {
            // oxlint-disable-next-line no-console
            if (import.meta.env.DEV) console.error('[code-copy] clipboard write failed', err);
          }
        });
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCodeCopy);
    } else {
      initCodeCopy();
    }
  </script>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="layout">
      <slot />
    </div>
  </body>
</html>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  // `.layout` is both a flex container AND a container-query containment context
  // for descendants. It can't filter @container rules against itself, so its own
  // flex-direction toggle stays on viewport-width media queries; child components
  // (Sidebar inner padding, PostLayout home button) still use @container layout.
  .layout {
    max-width: $layout-width;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    container-type: inline-size;
    container-name: layout;
  }

  @include breakpoint-sm {
    .layout {
      flex-direction: row;
      align-items: flex-start;

      :global(aside.sidebar) {
        // Subtract the 30px gutter so sidebar + gutter + page = 100% exactly,
        // otherwise flex-shrink: 0 lets total width exceed the viewport.
        flex: 0 0 calc((100% * 5 / 12) - 1.875rem);
        max-width: calc((100% * 5 / 12) - 1.875rem);
        margin-right: 1.875rem;
      }

      :global(main.page) {
        flex: 0 0 calc(100% * 7 / 12);
        max-width: calc(100% * 7 / 12);
      }

      :global(main.post-main) {
        width: 100%;
      }
    }
  }

  @include breakpoint-md {
    .layout {
      :global(aside.sidebar) {
        flex: 0 0 calc((100% / 3) - 1.875rem);
        max-width: calc((100% / 3) - 1.875rem);
      }

      :global(main.page) {
        flex: 0 0 calc(100% * 2 / 3);
        max-width: calc(100% * 2 / 3);
      }
    }
  }
</style>
