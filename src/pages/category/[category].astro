---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Page from '../../components/Page.astro';
import Feed from '../../components/Feed.astro';
import siteConfig from '../../site.config';
import {
  getPublishedPosts,
  kebabCase,
  summarizeCategories,
  type Post,
} from '../../lib/posts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const categories = summarizeCategories(posts);
  return categories.map((cat) => ({
    params: { category: kebabCase(cat.name) },
    props: {
      categoryName: cat.name,
      posts: posts.filter((p) => p.data.category === cat.name),
    },
  }));
}) satisfies GetStaticPaths;

interface Props {
  categoryName: string;
  posts: Post[];
}

const { categoryName, posts } = Astro.props;
---

<BaseLayout
  title={`${categoryName} - ${siteConfig.title}`}
  description={siteConfig.subtitle}
>
  <Sidebar />
  <Page title={categoryName}>
    <Feed posts={posts} />
  </Page>
</BaseLayout>
