---
import { Picture } from 'astro:assets';
import siteConfig from '../site.config';
import authorPhoto from '../assets/photo.jpg';

interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;
const { author } = siteConfig;
const TitleTag = isIndex ? 'h1' : 'h2';
---

<div class="author">
  <a href="/">
    <Picture
      src={authorPhoto}
      class="author__photo"
      width={150}
      height={150}
      densities={[1, 2]}
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      alt={author.name}
    />
  </a>
  <TitleTag class="author__title">
    <a class="author__title-link" href="/">{author.name}</a>
  </TitleTag>
  <p class="author__subtitle">{author.bio}</p>
</div>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .author {
    &__photo {
      display: inline-block;
      width: 75px;
      height: 75px;
      margin-bottom: 0;
      border-radius: 50%;
      background-clip: padding-box;
    }

    &__title {
      font-size: $typographic-base-font-size * 1.125;
      font-weight: 600;
      @include line-height(1.125);
      @include margin(0.5, 0, 0.5, 0);

      &-link {
        color: var(--text);

        &:hover,
        &:focus-visible {
          color: var(--text);
        }
      }
    }

    &__subtitle {
      color: var(--text-muted);
      @include line-height(1);
      @include margin-bottom(1);
    }
  }
</style>
