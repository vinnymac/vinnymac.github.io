---
import Author from './Author.astro';
import Menu from './Menu.astro';
import Contacts from './Contacts.astro';
import Copyright from './Copyright.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;
---

<aside class="sidebar">
  <div class="sidebar__inner">
    <div class="sidebar__header">
      <Author isIndex={isIndex} />
      <Menu />
    </div>
    <footer class="sidebar__footer">
      <Contacts />
      <div class="sidebar__footer-aside">
        <div class="sidebar__theme">
          <ThemeToggle />
        </div>
        <Copyright />
      </div>
    </footer>
  </div>
</aside>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  // Mobile: flatten the sidebar so __header and __footer become direct flex
  // items of .layout alongside <main class="page">. Then push __footer past the
  // page with `order`, so the most relevant content (Author/Menu, then articles)
  // is at the top and secondary chrome is at the bottom of the viewport.
  .sidebar {
    width: 100%;
    display: contents;

    &__inner {
      display: contents;
    }

    &__header {
      padding: 25px 20px 0;
    }

    &__footer {
      order: 2;
      padding: 30px 20px;
      margin-top: 24px;
      border-top: 1px solid var(--border-subtle);

      // Mobile two-section footer:
      //   [icon row 1]   [theme toggle]
      //   [icon row 2]   [© All rights]
      // space-between horizontally pins icons left, aside right;
      // align-items: stretch makes the aside column match the icons' height
      // so the inner space-between can pin theme top and copyright bottom.
      display: flex;
      justify-content: space-between;
      align-items: stretch;
      gap: 20px;
    }

    &__footer-aside {
      // Two equal-height rows that mirror the two icon rows on the left:
      //   row 1 → theme toggle (aligned with icon row 1)
      //   row 2 → copyright    (aligned with icon row 2)
      // The wrapper stretches to the icons' height (via the parent's
      // align-items: stretch), 1fr 1fr splits it 50/50, then each item is
      // vertically centered in its row and right-justified.
      display: grid;
      grid-template-rows: 1fr 1fr;
      align-items: center;
      justify-items: end;
    }
  }

  // Desktop: restore the original two-column sidebar — __header and __footer
  // stack inside __inner as before, and the flex sizing from BaseLayout takes
  // over again.
  @container layout (min-width: #{$layout-breakpoint-sm}) {
    .sidebar {
      display: block;

      &__inner {
        display: block;
        position: relative;
        padding: 30px 20px 0;

        &::after {
          background: linear-gradient(
            to bottom,
            var(--border-subtle) 0%,
            var(--border-subtle) 48%,
            var(--surface) 100%
          );
          position: absolute;
          content: '';
          width: 1px;
          height: 540px;
          top: 30px;
          right: -10px;
          bottom: 0;
        }
      }

      &__header,
      &__footer {
        padding: 0;
      }

      &__footer {
        // Drop the mobile-only flex; let children flow naturally inside the
        // sidebar column again.
        display: block;
        order: 0;
        margin-top: 0;
        border-top: 0;
        gap: 0;
      }

      &__footer-aside {
        // Flatten the wrapper so theme + copyright stack as direct sidebar children.
        display: contents;
      }

      &__theme {
        @include margin-bottom(0.5);
      }
    }
  }

  @container layout (min-width: #{$layout-breakpoint-md}) {
    .sidebar {
      &__inner {
        padding: 40px;
      }
    }
  }
</style>
