---
import Author from './Author.astro';
import Menu from './Menu.astro';
import Contacts from './Contacts.astro';
import Copyright from './Copyright.astro';

interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;
---

<aside class="sidebar">
  <div class="sidebar__inner">
    <Author isIndex={isIndex} />
    <Menu />
    <Contacts />
    <Copyright />
  </div>
</aside>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .sidebar {
    width: 100%;
    &__inner {
      position: relative;
      padding: 25px 20px 0;
    }
  }

  @include breakpoint-sm {
    .sidebar {
      &__inner {
        padding: 30px 20px 0;
        &::after {
          background: linear-gradient(
            to bottom,
            $color-gray-border 0%,
            $color-gray-border 48%,
            $color-white 100%
          );
          position: absolute;
          content: '';
          width: 1px;
          height: 540px;
          top: 30px;
          right: -10px;
          bottom: 0;
        }
      }
    }
  }

  @include breakpoint-md {
    .sidebar {
      &__inner {
        padding: 40px;
      }
    }
  }
</style>
