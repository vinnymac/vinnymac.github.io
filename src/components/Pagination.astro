---
interface Props {
  prevUrl?: string;
  nextUrl?: string;
}

const { prevUrl, nextUrl } = Astro.props;
---

<nav class="pagination" aria-label="Pagination">
  <div class="pagination__prev">
    {prevUrl ? (
      <a rel="prev" href={prevUrl} class="pagination__prev-link" data-astro-prefetch>← Prev</a>
    ) : (
      <span
        class="pagination__prev-link pagination__prev-link--disable"
        aria-disabled="true"
      >
        ← Prev
      </span>
    )}
  </div>
  <div class="pagination__next">
    {nextUrl ? (
      <a rel="next" href={nextUrl} class="pagination__next-link" data-astro-prefetch>Next →</a>
    ) : (
      <span
        class="pagination__next-link pagination__next-link--disable"
        aria-disabled="true"
      >
        Next →
      </span>
    )}
  </div>
</nav>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .pagination {
    @include margin-top(2);
    display: flex;

    &__prev,
    &__next {
      width: 50%;
    }

    &__prev {
      text-align: left;
    }
    &__next {
      text-align: right;
    }

    &__prev-link,
    &__next-link {
      color: var(--color-secondary);
      font-size: 26px;
      font-weight: bold;

      &:hover,
      &:focus-visible {
        color: var(--color-primary);
      }

      &--disable {
        // Fallback for Safari < 16.2 without color-mix support.
        color: #bdbdbd;
        color: color-mix(in srgb, var(--color-gray) 70%, white);
      }
    }
  }
</style>
