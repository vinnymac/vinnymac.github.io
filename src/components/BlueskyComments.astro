---
/**
 * Bluesky / ATProto–powered comments.
 *
 * Workflow:
 *   1. Author posts about a new article on Bluesky and copies the post URL
 *      (https://bsky.app/profile/<handle>/post/<rkey>) into the post's
 *      frontmatter as `blueskyThreadUrl`.
 *   2. At page load, this component resolves the thread via the public
 *      app.bsky.feed.getPostThread XRPC endpoint and renders the replies.
 *   3. Readers reply on Bluesky; their reply appears here on the next page load.
 *
 * No tracking, no script tags from third parties, no account required to read.
 */
import siteConfig from '../site.config';

interface Props {
  threadUrl?: string;
}

const { threadUrl } = Astro.props;
const { blueskyHandle } = siteConfig;
const profileUrl = `https://bsky.app/profile/${blueskyHandle}`;
---

{threadUrl ? (
  <section class="bsky-comments" data-thread-url={threadUrl}>
    <header class="bsky-comments__header">
      <h2 class="bsky-comments__title">Comments</h2>
      <a
        class="bsky-comments__reply-cta"
        href={threadUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Reply on Bluesky
      </a>
    </header>
    <p class="bsky-comments__status" data-status>Loading replies…</p>
    <ol class="bsky-comments__list" data-list hidden></ol>
    <template data-template>
      <li class="bsky-comments__item">
        <a class="bsky-comments__avatar-link" target="_blank" rel="noopener noreferrer">
          <img
            class="bsky-comments__avatar"
            alt=""
            width="40"
            height="40"
            loading="lazy"
            decoding="async"
          />
        </a>
        <div class="bsky-comments__body">
          <div class="bsky-comments__author">
            <a class="bsky-comments__author-name" target="_blank" rel="noopener noreferrer"></a>
            <a class="bsky-comments__author-handle" target="_blank" rel="noopener noreferrer"></a>
            <a class="bsky-comments__time-link" target="_blank" rel="noopener noreferrer">
              <time class="bsky-comments__time"></time>
            </a>
          </div>
          <div class="bsky-comments__text"></div>
          <div class="bsky-comments__stats">
            <span class="bsky-comments__stat" data-likes>♥ 0</span>
            <span class="bsky-comments__stat" data-reposts>↻ 0</span>
            <span class="bsky-comments__stat" data-replies>💬 0</span>
          </div>
        </div>
      </li>
    </template>
  </section>
) : (
  <section class="bsky-comments bsky-comments--empty">
    <h2 class="bsky-comments__title">Comments</h2>
    <p>
      This post doesn't have a discussion thread yet. Find me at
      <a href={profileUrl} target="_blank" rel="noopener noreferrer">
        @{blueskyHandle}
      </a> on Bluesky to chat.
    </p>
  </section>
)}

<script>
  interface BskyAuthor {
    did: string;
    handle: string;
    displayName?: string;
    avatar?: string;
  }
  interface BskyFacetFeature {
    $type:
      | 'app.bsky.richtext.facet#link'
      | 'app.bsky.richtext.facet#mention'
      | 'app.bsky.richtext.facet#tag';
    uri?: string;
    did?: string;
    tag?: string;
  }
  interface BskyFacet {
    index: { byteStart: number; byteEnd: number };
    features: BskyFacetFeature[];
  }
  interface BskyPostRecord {
    text?: string;
    createdAt?: string;
    facets?: BskyFacet[];
  }
  interface BskyPost {
    uri: string;
    cid: string;
    author: BskyAuthor;
    record: BskyPostRecord;
    likeCount?: number;
    repostCount?: number;
    replyCount?: number;
  }
  interface BskyThreadView {
    post: BskyPost;
    replies?: BskyThreadView[];
  }
  interface BskyThreadResponse {
    thread: BskyThreadView | { notFound: true } | { blocked: true };
  }

  const APPVIEW = 'https://public.api.bsky.app';
  const MAX_NESTED_DEPTH = 4;
  const RETRY_DELAY_MS = 1000;

  /** Parse a Bluesky web URL into the AT URI we need for getPostThread. */
  const parseThreadUrl = (url: string): { handle: string; rkey: string } | null => {
    try {
      const u = new URL(url);
      const match = u.pathname.match(/^\/profile\/([^/]+)\/post\/([^/]+)\/?$/);
      if (!match) return null;
      return { handle: match[1], rkey: match[2] };
    } catch {
      return null;
    }
  };

  /** Fetch with a single retry — masks transient AppView 429/5xx blips. */
  const fetchWithRetry = async (url: string): Promise<Response> => {
    try {
      const res = await fetch(url);
      if (res.ok) return res;
      if (res.status < 500 && res.status !== 429) {
        throw new Error(`${url}: ${res.status}`);
      }
      // 429 or 5xx — back off once then retry.
    } catch {
      // Network failure — retry once.
    }
    await new Promise((r) => setTimeout(r, RETRY_DELAY_MS));
    const retry = await fetch(url);
    if (!retry.ok) throw new Error(`${url}: ${retry.status}`);
    return retry;
  };

  const resolveDid = async (handle: string): Promise<string> => {
    const res = await fetchWithRetry(
      `${APPVIEW}/xrpc/com.atproto.identity.resolveHandle?handle=${encodeURIComponent(handle)}`,
    );
    const data = (await res.json()) as { did: string };
    return data.did;
  };

  const fetchThread = async (atUri: string): Promise<BskyThreadResponse> => {
    const res = await fetchWithRetry(
      `${APPVIEW}/xrpc/app.bsky.feed.getPostThread?uri=${encodeURIComponent(atUri)}&depth=10`,
    );
    return (await res.json()) as BskyThreadResponse;
  };

  /**
   * Split post text into segments along facet boundaries.
   * Bluesky facet offsets are UTF-8 byte indices — slicing the JS string directly
   * is wrong whenever the text contains multi-byte characters (emoji, accents, CJK).
   */
  const segmentText = (
    text: string,
    facets: BskyFacet[] = [],
  ): Array<{ text: string; feature?: BskyFacetFeature }> => {
    if (!facets.length) return [{ text }];
    const encoder = new TextEncoder();
    const decoder = new TextDecoder();
    const bytes = encoder.encode(text);
    const sorted = facets.toSorted((a, b) => a.index.byteStart - b.index.byteStart);
    const segments: Array<{ text: string; feature?: BskyFacetFeature }> = [];
    let cursor = 0;
    for (const facet of sorted) {
      const { byteStart, byteEnd } = facet.index;
      // Skip malformed or overlapping facets rather than throw.
      if (byteEnd <= byteStart || byteStart < cursor || byteEnd > bytes.length) continue;
      if (byteStart > cursor) {
        segments.push({ text: decoder.decode(bytes.slice(cursor, byteStart)) });
      }
      segments.push({
        text: decoder.decode(bytes.slice(byteStart, byteEnd)),
        feature: facet.features[0],
      });
      cursor = byteEnd;
    }
    if (cursor < bytes.length) {
      segments.push({ text: decoder.decode(bytes.slice(cursor)) });
    }
    return segments;
  };

  /** Append a plain-text segment, preserving `\n` as <br>. Uses textContent — safe. */
  const appendPlainText = (target: HTMLElement, value: string) => {
    const lines = value.split('\n');
    lines.forEach((line, i) => {
      if (line) target.appendChild(document.createTextNode(line));
      if (i < lines.length - 1) target.appendChild(document.createElement('br'));
    });
  };

  /** Render post text + facets into `target` as real DOM nodes (no innerHTML). */
  const renderFacetedText = (
    target: HTMLElement,
    text: string,
    facets?: BskyFacet[],
  ) => {
    target.replaceChildren();
    for (const segment of segmentText(text, facets)) {
      const feature = segment.feature;
      if (!feature) {
        appendPlainText(target, segment.text);
        continue;
      }
      const anchor = document.createElement('a');
      anchor.target = '_blank';
      anchor.textContent = segment.text;
      if (feature.$type === 'app.bsky.richtext.facet#link' && feature.uri) {
        anchor.href = feature.uri;
        anchor.rel = 'noopener noreferrer nofollow';
      } else if (feature.$type === 'app.bsky.richtext.facet#mention' && feature.did) {
        anchor.href = `https://bsky.app/profile/${feature.did}`;
        anchor.rel = 'noopener noreferrer';
      } else if (feature.$type === 'app.bsky.richtext.facet#tag' && feature.tag) {
        anchor.href = `https://bsky.app/hashtag/${encodeURIComponent(feature.tag)}`;
        anchor.rel = 'noopener noreferrer';
      } else {
        // Unknown feature — fall back to plain text.
        appendPlainText(target, segment.text);
        continue;
      }
      target.appendChild(anchor);
    }
  };

  const renderReply = (
    template: HTMLTemplateElement,
    reply: BskyThreadView,
    depth: number,
  ): HTMLElement | null => {
    const { post } = reply;
    if (!post?.author || !post.record) return null;
    const fragment = template.content.cloneNode(true) as DocumentFragment;
    const item = fragment.querySelector('.bsky-comments__item') as HTMLElement;
    if (depth > 0) {
      item.classList.add('bsky-comments__item--nested');
      item.style.setProperty('--depth', String(Math.min(depth, MAX_NESTED_DEPTH)));
    }
    const avatarLink = fragment.querySelector('.bsky-comments__avatar-link') as HTMLAnchorElement;
    const avatar = fragment.querySelector('.bsky-comments__avatar') as HTMLImageElement;
    const nameLink = fragment.querySelector('.bsky-comments__author-name') as HTMLAnchorElement;
    const handleLink = fragment.querySelector('.bsky-comments__author-handle') as HTMLAnchorElement;
    const timeLink = fragment.querySelector('.bsky-comments__time-link') as HTMLAnchorElement;
    const time = fragment.querySelector('.bsky-comments__time') as HTMLTimeElement;
    const text = fragment.querySelector('.bsky-comments__text') as HTMLElement;
    const likes = fragment.querySelector('[data-likes]') as HTMLElement;
    const reposts = fragment.querySelector('[data-reposts]') as HTMLElement;
    const replies = fragment.querySelector('[data-replies]') as HTMLElement;

    const profileUrl = `https://bsky.app/profile/${post.author.handle}`;
    const rkey = post.uri.split('/').pop();
    const postUrl = `${profileUrl}/post/${rkey}`;

    avatarLink.href = profileUrl;
    if (post.author.avatar) avatar.src = post.author.avatar;
    avatar.alt = post.author.displayName ?? post.author.handle;
    nameLink.href = profileUrl;
    nameLink.textContent = post.author.displayName ?? post.author.handle;
    handleLink.href = profileUrl;
    handleLink.textContent = `@${post.author.handle}`;
    timeLink.href = postUrl;
    timeLink.setAttribute('aria-label', `View reply on Bluesky`);
    if (post.record.createdAt) {
      time.dateTime = post.record.createdAt;
      time.textContent = new Date(post.record.createdAt).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
    }
    if (post.record.text) {
      renderFacetedText(text, post.record.text, post.record.facets);
    }
    likes.textContent = `♥ ${post.likeCount ?? 0}`;
    reposts.textContent = `↻ ${post.repostCount ?? 0}`;
    replies.textContent = `💬 ${post.replyCount ?? 0}`;

    return item;
  };

  /** Walk the thread tree depth-first, flattening into rendered elements. */
  const renderTree = (
    template: HTMLTemplateElement,
    replies: BskyThreadView[],
    depth: number,
    out: HTMLElement[],
  ) => {
    for (const reply of replies) {
      const el = renderReply(template, reply, depth);
      if (el) out.push(el);
      if (reply.replies?.length) {
        renderTree(template, reply.replies, depth + 1, out);
      }
    }
  };

  const loadComments = async (root: HTMLElement) => {
    const threadUrl = root.dataset.threadUrl;
    if (!threadUrl) return;

    const status = root.querySelector<HTMLElement>('[data-status]')!;
    const list = root.querySelector<HTMLElement>('[data-list]')!;
    const template = root.querySelector<HTMLTemplateElement>('[data-template]')!;

    try {
      const parsed = parseThreadUrl(threadUrl);
      if (!parsed) throw new Error('Invalid Bluesky thread URL');
      const did = await resolveDid(parsed.handle);
      const atUri = `at://${did}/app.bsky.feed.post/${parsed.rkey}`;
      const data = await fetchThread(atUri);
      const thread = data.thread;
      if (!('post' in thread)) {
        status.textContent = 'Thread is unavailable.';
        return;
      }
      const replies = thread.replies ?? [];
      if (replies.length === 0) {
        status.textContent = 'No replies yet — be the first to comment on Bluesky.';
        return;
      }
      const items: HTMLElement[] = [];
      renderTree(template, replies, 0, items);
      for (const el of items) list.appendChild(el);
      status.hidden = true;
      list.hidden = false;
    } catch (err) {
      // oxlint-disable-next-line no-console
      if (import.meta.env.DEV) console.error('[BlueskyComments]', err);
      status.textContent = 'Could not load comments.';
    }
  };

  /**
   * Defer the AppView XRPC call until the comments section is near the
   * viewport. Visitors who never scroll past the post body skip the network
   * entirely. The 600px rootMargin keeps perceived latency near-zero — by the
   * time the user scrolls to the comments, the fetch is usually done.
   */
  const init = () => {
    const root = document.querySelector<HTMLElement>('.bsky-comments[data-thread-url]');
    if (!root) return;

    if (!('IntersectionObserver' in window)) {
      loadComments(root);
      return;
    }

    const io = new IntersectionObserver(
      (entries, observer) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            observer.disconnect();
            loadComments(root);
            return;
          }
        }
      },
      { rootMargin: '600px 0px' },
    );
    io.observe(root);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .bsky-comments {
    max-width: $layout-post-width;
    margin: 0 auto;
    @include margin-top(2);
    @include margin-bottom(2);
    padding-top: 24px;
    border-top: 1px solid var(--color-gray-border);

    &__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    &__title {
      font-size: $typographic-base-font-size * 1.375;
      margin: 0;
    }

    &__reply-cta {
      display: inline-block;
      height: $button-height;
      line-height: $button-height;
      padding: 0 18px;
      border: 1px solid var(--color-gray-border);
      border-radius: $button-border-radius;
      color: var(--color-base);
      font-size: $typographic-small-font-size;

      &:hover,
      &:focus-visible {
        color: var(--color-primary);
        border-color: var(--color-primary);
      }
    }

    &__status {
      color: var(--color-gray);
      font-style: italic;
      margin: 16px 0;
    }

    &__list {
      list-style: none;
      padding: 0;
      margin: 16px 0 0;
    }

    &__item {
      display: flex;
      gap: 12px;
      padding: 16px 0;
      border-bottom: 1px solid var(--color-gray-bg);

      // Nested replies — `--depth` is set inline by the renderer (1..4).
      &--nested {
        margin-left: calc(var(--depth, 1) * 24px);
        padding-left: 12px;
        border-left: 2px solid var(--color-gray-bg);
      }
    }

    &__avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--color-gray-bg);
      display: block;
    }

    &__body {
      flex: 1;
      min-width: 0;
    }

    &__author {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
      font-size: $typographic-small-font-size;
    }

    &__author-name {
      font-weight: 600;
      color: var(--color-base);
    }

    &__author-handle {
      color: var(--color-gray);
    }

    &__time-link {
      margin-left: auto;
      color: var(--color-gray);

      &:hover,
      &:focus-visible {
        color: var(--color-primary);
      }
    }

    &__time {
      color: inherit;
    }

    &__text {
      margin-top: 4px;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    &__stats {
      margin-top: 6px;
      display: flex;
      gap: 16px;
      font-size: $typographic-small-font-size;
      color: var(--color-gray);
    }

    &--empty {
      font-style: italic;
      color: var(--color-gray);
    }
  }
</style>
