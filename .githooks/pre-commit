#!/usr/bin/env bash
# Runs oxfmt --check and oxlint on staged files only.
# Bypass with: git commit --no-verify
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

fmt_files=$(printf '%s\n' "$staged" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|jsonc|json5|ya?ml|toml|md|mdx|css|scss|less|html)$' || true)
lint_files=$(printf '%s\n' "$staged" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|astro)$' || true)

if [ -n "$fmt_files" ]; then
  printf '%s\n' "$fmt_files" | xargs pnpm exec oxfmt --check
fi

if [ -n "$lint_files" ]; then
  printf '%s\n' "$lint_files" | xargs pnpm exec oxlint
fi
